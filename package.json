    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm check --staged --no-errors-on-unmatched"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
