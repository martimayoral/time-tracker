{
  "name": "time-tracker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "check": "biome check",
    "postinstall": "simple-git-hooks",
    "check:fix": "biome check --write . && tsc -b --noEmit"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm check --staged --no-errors-on-unmatched"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "shadcn": "^4.11.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "simple-git-hooks": "^2.13.1",
    "oxlint": "^1.69.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.0"
  }
}
